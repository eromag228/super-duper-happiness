def fuel_check(fuel, consumption, distance):
    """
    Проверка достаточности топлива до заправки.
    """
    # Сколько топлива будет потрачено на дорогу
    needed = (distance / 100) * consumption
    remainder = fuel - needed
    
    if remainder < 0:
        return "Остановка: Топливо закончится раньше!"
    # Исправлено: предупреждение при остатке < 5 литров
    elif remainder < 5:
        return "Предупреждение: Низкий уровень топлива!"
    else:
        return "Топлива достаточно"


# ========== ТЕСТ-КЕЙСЫ ==========
print("\n" + "=" * 60)
print("Задание №3. Тестирование контроля топлива")

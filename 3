# 1. НОРМАЛЬНЫЕ ДАННЫЕ
print("\n--- НОРМАЛЬНЫЕ ДАННЫЕ ---")
test_normal = fuel_check(50, 10, 200)  # нужно 20 л, остаток 30 л
print(f"Вход: fuel=50, consumption=10, distance=200")
print(f"Результат: {test_normal}")
print(f"Ожидание: Топлива достаточно")
print(f"Вердикт: {'✅ ПРОЙДЕН' if test_normal == 'Топлива достаточно' else '❌ НЕ ПРОЙДЕН'}")

# 2. ГРАНИЧНЫЕ ЗНАЧЕНИЯ
print("\n--- ГРАНИЧНЫЕ ЗНАЧЕНИЯ ---")
test_boundary = fuel_check(25, 10, 200)  # нужно 20 л, остаток 5 л (ровно)
print(f"Вход: fuel=25, consumption=10, distance=200")

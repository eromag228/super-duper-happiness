# 1. НОРМАЛЬНЫЕ ДАННЫЕ
print("\n--- НОРМАЛЬНЫЕ ДАННЫЕ ---")
test_normal = calculate_cart([1500, 2000, 2500])  # сумма 6000
print(f"Вход: [1500, 2000, 2500]")
print(f"Результат: {test_normal}")
print(f"Ожидание: 5900 (скидка 10% = 5400 + доставка 500)")
print(f"Вердикт: {'✅ ПРОЙДЕН' if test_normal == 5900 else '❌ НЕ ПРОЙДЕН'}")


def calculate_cart(prices):
    """
    Расчет итоговой суммы корзины с учетом скидок и доставки.
    """
    total = sum(prices)
    
    # Исправлено: сначала проверяем большую скидку
    if total > 10000:
        total = total * 0.8  # скидка 20%
    elif total > 5000:
        total = total * 0.9  # скидка 10%
    
    # Исправлено: проверяем сумму ПОСЛЕ скидки
    # Если сумма после скидки <= 3000, добавляем доставку
    if total <= 3000:
        total = total + 500
    
    return total



def moderator(text):
    """
    Проверка сообщения на наличие запрещенных слов и длины.
    """
    # Проверка на пустое сообщение
    if not text:
        return False
    
    # Исправлено: приведение к нижнему регистру для регистронезависимости
    text_lower = text.lower()
    
    # Проверка запрещенных слов
    if "спам" in text_lower or "реклама" in text_lower:
        return False
    
    # Исправлено: сообщение короче 3 символов (не включая 3)
    if len(text) < 3:
        return False
    
    return True


